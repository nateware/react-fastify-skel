# Server
FASTIFY_PORT=3001
FASTIFY_ADDRESS=0.0.0.0
FASTIFY_LOG_LEVEL=info

# Database (local dev)
DATABASE_URL=postgresql://devuser:devpass@localhost:5432/app

# CORS (optional — defaults to reflecting request origin)
# CORS_ORIGIN=https://myapp.example.com

# Auth
JWT_SECRET=change-me-local-dev-secret
FRONTEND_URL=http://localhost:5173

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Apple Sign In (https://developer.apple.com/account/resources)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=http://localhost:3001/api/auth/apple/callback
