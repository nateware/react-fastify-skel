{
  "name": "backend",
  "version": "1.0.0",
  "description": "Fastify backend API server.",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "fastify start -w -l info -P src/app.ts",
    "build": "tsc",
    "start": "fastify start -l info dist/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "rm -rf dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/sensible": "^6.0.0",
    "fastify": "^5.0.0",
    "fastify-cli": "^7.4.1",
    "fastify-plugin": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4.19.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.0"
  }
}
