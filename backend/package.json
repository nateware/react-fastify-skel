{
  "name": "backend",
  "version": "1.0.0",
  "description": "Fastify backend API server.",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "node --env-file=.env node_modules/.bin/fastify start -w -l info -P --import tsx src/app.ts",
    "build": "tsc",
    "start": "fastify start -l info -a 0.0.0.0 dist/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "node dist/db/migrate.js",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/sensible": "^6.0.0",
    "@google-cloud/cloud-sql-connector": "^1.9.1",
    "arctic": "^3.7.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.1",
    "fastify-cli": "^7.4.1",
    "fastify-plugin": "^5.0.0",
    "jose": "^6.1.3",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.0"
  }
}
